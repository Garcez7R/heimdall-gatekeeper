# Heimdall Gatekeeper - Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# APPLICATION SETTINGS
# ==========================================
HEIMDALL_PRODUCT_NAME=Heimdall Gatekeeper
HEIMDALL_TAGLINE=Enterprise SIEM for Blue Teams
HEIMDALL_DEFAULT_LANGUAGE=pt-BR
HEIMDALL_DEFAULT_THEME=dark
HEIMDALL_SPLASH_DURATION_MS=1200

# ==========================================
# STORAGE CONFIGURATION
# ==========================================
HEIMDALL_SQLITE_PATH=data/heimdall.db
HEIMDALL_CLOUDFLARE_D1_ENABLED=false

# ==========================================
# SECURITY & AUTHENTICATION
# ==========================================
HEIMDALL_JWT_SECRET=change-me-in-production-please-use-strong-random-key
HEIMDALL_API_KEY=demo-key
JWT_EXPIRY_HOURS=24
RATE_LIMIT_REQUESTS=600
RATE_LIMIT_WINDOW=3600

# ==========================================
# REDIS CACHE (Optional - improves performance)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==========================================
# PROMETHEUS MONITORING (Optional)
# ==========================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ==========================================
# AUDIT & COMPLIANCE
# ==========================================
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=365

# ==========================================
# THREAT INTELLIGENCE FEEDS
# ==========================================
# AlienVault OTX (https://otx.alienvault.com/)
OTX_API_KEY=

# MISP Threat Sharing (https://www.misp-project.org/)
MISP_URL=
MISP_API_KEY=

# AbuseIPDB (https://www.abuseipdb.com/)
ABUSEIPDB_API_KEY=

# VirusTotal (https://www.virustotal.com/)
VIRUSTOTAL_API_KEY=

# Shodan (https://www.shodan.io/)
SHODAN_API_KEY=

# ==========================================
# SIEM INTEGRATIONS
# ==========================================
# Splunk HTTP Event Collector
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
SPLUNK_INDEX=heimdall

# Elasticsearch
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=heimdall

# ==========================================
# CLOUDFLARE DEPLOYMENT (for production)
# ==========================================
CF_ACCOUNT_ID=
CF_API_TOKEN=
HEIMDALL_GRAFANA_URL=

# ==========================================
# DEVELOPMENT SETTINGS
# ==========================================
DEBUG=false
LOG_LEVEL=INFO
